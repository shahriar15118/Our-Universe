rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function existingData() {
      return resource.data;
    }

    function incomingData() {
      return request.resource.data;
    }

    function getProfile(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasCouple(uid) {
      return exists(/databases/$(database)/documents/users/$(uid)) && 
             getProfile(uid).get('coupleId', null) != null;
    }

    function isMemberOf(uid, cid) {
      return isSignedIn() && hasCouple(uid) && getProfile(uid).coupleId == cid;
    }

    // --- Collections ---

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && 
                      incomingData().userId == userId &&
                      incomingData().keys().hasAll(['userId', 'name']);
      allow update: if isOwner(userId) || 
                      (isSignedIn() && 
                       hasCouple(request.auth.uid) && 
                       getProfile(request.auth.uid).coupleId == existingData().get('coupleId', null) &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['photoUrl']));
      allow delete: if false;
    }

    match /couples/{coupleId} {
      allow read: if isSignedIn() && (request.auth.uid in existingData().get('spouseIds', []));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
                      (request.auth.uid in existingData().get('spouseIds', [])) ||
                      (request.auth.token.email.lower() in existingData().get('emails', []))
                    );
      
      match /letters/{letterId} {
        allow read, write: if isMemberOf(request.auth.uid, coupleId);
      }
      
      match /deen_daily/{date} {
        allow read, write: if isMemberOf(request.auth.uid, coupleId);
      }

      match /secrets/{secretId} {
        allow read, write: if isMemberOf(request.auth.uid, coupleId);
      }

      match /moods/{moodId} {
        allow read, write: if isMemberOf(request.auth.uid, coupleId);
      }
    }

    match /memories/{memoryId} {
      // List/read memories belonging to the user's couple
      allow read: if isSignedIn() && (
        resource == null || isMemberOf(request.auth.uid, existingData().coupleId)
      );
      
      allow create: if isSignedIn() && 
                      incomingData().authorId == request.auth.uid &&
                      isMemberOf(request.auth.uid, incomingData().coupleId);
        
      allow update: if isSignedIn() && 
                      isMemberOf(request.auth.uid, existingData().coupleId);

      allow delete: if isSignedIn() && (
                      existingData().authorId == request.auth.uid ||
                      isMemberOf(request.auth.uid, existingData().coupleId)
                    );
    }
  }
}
