{
  "entities": {
    "Couple": {
      "title": "Couple",
      "description": "Shared space linking two spouses.",
      "type": "object",
      "properties": {
        "coupleCode": { "type": "string", "description": "6-digit private link key" },
        "spouseIds": { "type": "array", "items": { "type": "string" } },
        "weddingDate": { "type": "string", "format": "date-time" },
        "anniversary": { "type": "string", "format": "date-time" },
        "theme": { "type": "string", "enum": ["Moonlit Night", "Desert Rose", "Ocean Calm", "Golden Dusk"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deenStreak": { "type": "integer" },
        "lastDeenDate": { "type": "string" }
      },
      "required": ["coupleCode", "spouseIds", "createdAt"]
    },
    "DeenDaily": {
      "title": "DeenDaily",
      "description": "Daily spiritual progress for the couple.",
      "type": "object",
      "properties": {
        "notes": { "type": "array" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Individual spouse profile.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "coupleId": { "type": "string" },
        "name": { "type": "string" },
        "photoUrl": { "type": "string" },
        "role": { "type": "string", "enum": ["husband", "wife"] }
      },
      "required": ["userId", "coupleId", "name"]
    },
    "Memory": {
      "title": "Memory",
      "description": "A shared milestone or photo.",
      "type": "object",
      "properties": {
        "coupleId": { "type": "string" },
        "type": { "type": "string", "enum": ["photo", "video", "audio", "note"] },
        "mediaUrl": { "type": "string" },
        "caption": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "emotion": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "likes": { "type": "array", "items": { "type": "string" } },
        "isLocked": { "type": "boolean" }
      },
      "required": ["coupleId", "type", "date"]
    },
    "Letter": {
      "title": "Letter",
      "description": "Private letters written for specific moments.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "coupleId": { "type": "string" },
        "category": { "type": "string" },
        "title": { "type": "string" },
        "contentEncrypted": { "type": "string" },
        "isOpened": { "type": "boolean" },
        "openedAt": { "type": "string", "format": "date-time" },
        "scheduledFor": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "coupleId", "title", "contentEncrypted", "createdAt"]
    },
    "DailySecret": {
      "title": "DailySecret",
      "description": "A secret shared for the day.",
      "type": "object",
      "properties": {
        "coupleId": { "type": "string" },
        "authorId": { "type": "string" },
        "text": { "type": "string" },
        "date": { "type": "string" },
        "isRevealed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["coupleId", "authorId", "text", "date", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A comforting Quranic verse saved as a spiritual anchor.",
      "type": "object",
      "properties": {
        "ayah": { "type": "string" },
        "ref": { "type": "string" },
        "trans": { "type": "string" },
        "tafsir": { "type": "string" },
        "dua": { "type": "object" },
        "emotion": { "type": "string" },
        "savedBy": { "type": "string" },
        "savedByName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ayah", "ref", "trans", "emotion", "savedBy"]
    },
    "Mood": {
      "title": "Mood",
      "description": "A shared mood status from a spouse.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "emotion": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "emotion", "text"]
    },
    "DeenLog": {
      "title": "DeenLog",
      "description": "Spiritual deeds logged by a spouse.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "actionType": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "date": { "type": "string" }
      },
      "required": ["userId", "actionType", "text"]
    }
  },
  "firestore": {
    "/couples/{coupleId}": {
      "schema": "Couple",
      "description": "The shared couple document."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Spouse profile data."
    },
    "/memories/{memoryId}": {
      "schema": "Memory",
      "description": "Memories belonging to a couple."
    },
    "/couples/{coupleId}/secrets/{secretId}": {
      "schema": "DailySecret",
      "description": "Secrets shared between a couple."
    },
    "/couples/{coupleId}/letters/{letterId}": {
      "schema": "Letter",
      "description": "Secret letters for a couple."
    },
    "/couples/{coupleId}/deen_daily/{date}": {
      "schema": "DeenDaily",
      "description": "Daily deen tracking data for the couple."
    },
    "/couples/{coupleId}/moods/{moodId}": {
      "schema": "Mood",
      "description": "Shared emotional moods."
    },
    "/couples/{coupleId}/favorites/{favoriteId}": {
      "schema": "Favorite",
      "description": "Spiritual anchors saved by the couple."
    },
    "/couples/{coupleId}/deen_logs/{logId}": {
      "schema": "DeenLog",
      "description": "Logged spiritual activities."
    }
  }
}
